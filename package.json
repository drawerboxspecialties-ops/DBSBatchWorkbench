{
  "name": "dbs-batch-workbench",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "DBS Drawers batch workbench — paired Top Edge report + OptiCut cut-list tools for the same order batch (two CSV imports).",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,mjs,css,html,md,json}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,css,html,md,json}\"",
    "deploy": "npm run build && node scripts/publish-docs.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.0.0",
    "jszip": "^3.10.1",
    "prettier": "^3.3.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "firebase": "^12.16.0"
  }
}
